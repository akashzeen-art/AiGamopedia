{
  "installCommand": "echo 'Skip install'",
  "buildCommand": "sh scripts/vercel-build.sh",
  "outputDirectory": ".vercel/output/static",
  "framework": "other",
  "rewrites": [
    { "source": "/ar", "destination": "/index.html" },
    { "source": "/ar/", "destination": "/index.html" },
    { "source": "/ar/index.html", "destination": "/index.html" },
    { "source": "/ar/moreGames.html", "destination": "/moreGames.html" },
    { "source": "/ar/myAccount.html", "destination": "/myAccount.html" },
    { "source": "/ar/termsAndConditions.html", "destination": "/termsAndConditions.html" },
    { "source": "/ar/(.*)", "destination": "/$1" }
  ]
}
